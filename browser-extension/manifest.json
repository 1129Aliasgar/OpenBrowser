{
  "manifest_version": 3,
  "name": "OpenBrowser Bridge",
  "version": "0.7.7",
  "description": "Connects browser AI chat pages to the local OpenBrowser bridge server.",
  "permissions": ["activeTab", "alarms", "scripting", "storage", "tabs"],
  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://chat.deepseek.com/*",
    "https://claude.ai/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://chat.z.ai/*",
    "https://glm.ai/*",
    "https://open.bigmodel.cn/*",
    "https://grok.com/*",
    "https://x.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://chat.deepseek.com/*",
        "https://claude.ai/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://chat.z.ai/*",
        "https://glm.ai/*",
        "https://open.bigmodel.cn/*",
        "https://grok.com/*",
        "https://x.com/*"
      ],
      "js": ["src/providers.js", "src/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "OpenBrowser"
  }
}
